<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Proyecto_Evently"
             xmlns:vm="clr-namespace:Proyecto_Evently.ViewModels"
             x:Class="Proyecto_Evently.Views.Ordenes"
             
             Title="Ordenes">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="15">

            <Label Text="NUEVO REGISTRO DE LOTE" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2B3A67"
                   Margin="0,0,0,10"/>

            <!-- Código del Lote -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Código del Lote" FontAttributes="Bold" />
                <Frame Padding="10,2" BorderColor="Gray" CornerRadius="8">
                    <Entry Text="{Binding CodigoLote}" 
                           Placeholder="Ej: LOTE-001" 
                           VerticalOptions="Center"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Picker Origen -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Punto de Origen" FontAttributes="Bold" />
                <Frame Padding="10,2" BorderColor="Gray" CornerRadius="8">
                    <Picker Title="Seleccione origen"
                            ItemsSource="{Binding Ubicaciones}"
                            ItemDisplayBinding="{Binding Nombre}"
                            SelectedItem="{Binding OrigenSeleccionado}" />
                </Frame>
            </VerticalStackLayout>

            <!-- Picker Destino (CORREGIDO) -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Punto de Destino" FontAttributes="Bold" />
                <Frame Padding="10,2" BorderColor="Gray" CornerRadius="8">
                    <Picker Title="Seleccione destino"
                            ItemsSource="{Binding Ubicaciones}"
                            ItemDisplayBinding="{Binding Nombre}"
                            SelectedItem="{Binding DestinoSeleccionado}" />
                </Frame>
            </VerticalStackLayout>

            <!-- Descripción -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Descripción opcional" FontAttributes="Bold" />
                <Frame Padding="10,2" BorderColor="Gray" CornerRadius="8">
                    <Editor Text="{Binding Descripcion}" 
                            Placeholder="Notas adicionales sobre el envío..." 
                            HeightRequest="100" 
                            AutoSize="TextChanges"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Botón de Acción -->
            <Button Text="GUARDAR LOTE"
                    Command="{Binding GuardarLoteCommand}"
                    HeightRequest="55"
                    CornerRadius="10"
                    BackgroundColor="#2B3A67"
                    TextColor="White"
                    FontAttributes="Bold"
                    Margin="0,15,0,0">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                        <Setter Property="IsEnabled" Value="False" />
                        <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- Indicador de Carga -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               IsVisible="{Binding IsBusy}" 
                               Color="#2B3A67" 
                               HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>